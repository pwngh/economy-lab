{
  "name": "economy-lab-docs",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "react-router dev",
    "build:runner": "vite build --config vite.runner.config.ts",
    "build": "npm run build:runner && react-router build && node scripts/copy-404.mjs",
    "preview": "vite preview",
    "typecheck": "react-router typegen && tsc",
    "format": "biome format --write .",
    "lint": "biome check .",
    "test": "vitest run",
    "check:csp": "node scripts/check-csp.mjs",
    "check:static": "node scripts/check-static.mjs",
    "check:ref": "node scripts/check-ref.mjs",
    "verify": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "@react-router/node": "7.18.0",
    "isbot": "5.1.44",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "7.18.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@mdx-js/rollup": "3.1.1",
    "@react-router/dev": "7.18.0",
    "@shikijs/rehype": "1.29.2",
    "@stefanprobst/rehype-extract-toc": "3.0.0",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "gray-matter": "4.0.3",
    "rehype-autolink-headings": "7.1.0",
    "rehype-external-links": "3.0.0",
    "rehype-slug": "6.0.0",
    "remark-frontmatter": "5.0.0",
    "remark-gfm": "4.0.1",
    "remark-mdx-frontmatter": "5.2.0",
    "remark-smartypants": "3.0.2",
    "typescript": "5.9.3",
    "vite": "6.4.3",
    "vitest": "4.1.9",
    "wrangler": "4.105.0",
    "zod": "3.25.76"
  }
}
