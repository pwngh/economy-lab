{
  "include": ["**/*.ts", "**/*.tsx", ".react-router/types/**/*"],
  // app/snippets compiles under scripts/check-samples.mjs (NodeNext, entry-point paths only) —
  // the lab's source graph doesn't typecheck under this config's DOM lib, and shouldn't have to.
  "exclude": ["node_modules", "runner", "public", "app/snippets"],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node", "vite/client"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "rootDirs": [".", "./.react-router/types"],
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/*"]
    },
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "allowImportingTsExtensions": true
  }
}
