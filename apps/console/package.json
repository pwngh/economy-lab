{
  "name": "economy-console-app",
  "private": true,
  "type": "module",
  "description": "Demo admin console for economy-lab: accounts, ledger, payouts, and integrity, driven by the live engine.",
  "license": "MIT",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "vite preview",
    "typecheck": "react-router typegen && node ./scripts/typecheck.mjs",
    "test": "vitest run",
    "verify": "npm run typecheck && npm run lint && npm run test",
    "budget": "react-router build && node ./scripts/bundle-budget.mjs",
    "lint": "biome check ."
  },
  "dependencies": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-router": "7.18.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@react-router/dev": "7.18.0",
    "@react-router/node": "7.18.0",
    "@types/node": "22.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "5.9.3",
    "vite": "7.3.5",
    "vitest": "^4.1.10"
  }
}
