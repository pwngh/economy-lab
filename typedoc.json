{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "src/index.ts",
    "src/ports.ts",
    "src/adapters/index.ts",
    "src/adapters/redis.ts",
    "src/adapters/sqs.ts",
    "src/engines/postgres.ts",
    "src/engines/mysql.ts",
    "src/engines/mysql-mariadb.ts",
    "src/worker/index.ts",
    "src/server.ts",
    "src/netting.ts",
    "src/ops/index.ts",
    "src/store-kit.ts",
    "test/conformance/index.ts"
