# The compose-local database URLs (docker-compose.yml), uncommented and ready to use. `make env`
# appends any of these keys that .env does not already define, under a "# from .env.compose" marker,
# so one `make env` (or `make bootstrap`) points every `npm test` / `npm run bench` at the compose
# rig with no per-command typing. Safe to commit: these credentials only ever reach local containers.
DATABASE_URL=postgres://economy:economy@localhost:55432/economy_lab
PG_URL=postgres://economy:economy@localhost:55432/economy_lab
MYSQL_TEST_URL=mysql://root:economy@localhost:53306/economy_lab
REDIS_URL=redis://localhost:56379
