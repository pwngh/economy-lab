# economy-lab — variable NAMES only. Never commit real values; .gitignore excludes .env*.
# Copy to .env and fill in for a real deployment. Config is read ONCE at the edge
# (loadConfig, src/config.ts) and injected; library modules never read the
# environment (§0.21). In production a missing required secret fails fast with a
# CONFIG.INVALID aggregate — there are no silent dev defaults in the library.

# --- Required secrets (production fails fast if unset) ---------------------------

# NODE_ENV=production makes WEBHOOK_SECRET + SIGNING_SECRET mandatory (loadConfig fails fast with
# CONFIG.INVALID); unset / any other value tolerates a blank secret for local dev. Separately, the
# serve/worker entry (scripts/main.ts) refuses to start if either is blank, in any NODE_ENV.
# NODE_ENV=production

# HMAC key used to verify inbound billing/settlement webhooks (Tilia/Steam/Meta).
WEBHOOK_SECRET=

# Key the Signer uses to sign chain checkpoints and entitlement-gated URLs.
SIGNING_SECRET=

# --- Production externals (REQUIRED when NODE_ENV=production; dev uses stubs) -----
# In production the serve/worker entry wires real CREDIT↔USD rates and a real payout provider and
# fails fast if any of these is unset/malformed — it never silently uses the 1:1 dev rate or an
# auto-approve payout. Outside production they default to those dev stubs, so a local run needs none.
# Rates are fixed-point: the real multiplier is rate / 10^scale, and usd_minor = floor(credit_minor
# × rate / 10^scale). The buy-vs-par gap is the platform's purchase spread (VRChat's ~40% "purchase
# fee"); defaults below are VRChat's published rates (buy ≈120 credits/USD, par/payout 200/USD).

# CREDIT_BUY_RATE=8333         # buy: USD a user pays per credit at top-up …
# CREDIT_BUY_SCALE=6           #   … e.g. rate 8333 / scale 6 ⇒ ≈$0.008333 (≈120 credits = $1)
# CREDIT_PAR_RATE=5            # par: credit's backing / cash-out value, for the backing check …
# CREDIT_PAR_SCALE=3           #   … e.g. rate 5 / scale 3 ⇒ 1.00 credit backed by $0.005
# PAYOUT_RATE=5                # payout: rate a creator's earned credits cash out at (= par) …
# PAYOUT_SCALE=3               #   … e.g. rate 5 / scale 3 ⇒ 1.00 credit pays out $0.005
# PROCESSOR_URL=https://payouts.internal/payout   # real payout provider (also honored in dev)
# PROCESSOR_API_KEY=                              # bearer token sent to PROCESSOR_URL

# --- Optional infrastructure (unset → the dependency-free in-memory adapter) -----

# DATABASE_URL=postgres://localhost:5432/economy_lab   # pg adapter
# DATABASE_URL=mysql://localhost:3306/economy_lab      # mysql adapter
# REDIS_URL=redis://localhost:6379                     # read-through cache; unset → no-op
# DISPATCHER_URL=https://bus.internal/economy          # outbox HTTP transport (SQS_QUEUE_URL wins if both set; neither → in-process)
# SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/.../economy  # SQS transport
# For LocalStack (docker compose), the AWS SDK reads these from the environment:
# AWS_REGION=us-east-1
# AWS_ENDPOINT_URL=http://localhost:4566               # point the SQS client at LocalStack
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test
# SQS_QUEUE_URL=http://localhost:4566/000000000000/economy  # LocalStack queue (create it first)

# --- Optional overrides (the value shown is the documented default) --------------

# Money is decimal-string at the edge, 2 fraction digits (cents); minor units in core.

# REPLAY_WINDOW_MS=300000          # accepted webhook timestamp skew (5 min)
# MAX_PAYOUT_ATTEMPTS=5            # provider attempts before a payout is reversed
# MAX_PAYOUT_AGE_MS=86400000       # a payout older than this (24h) is reversed by the SLA sweep
# MAX_OUTBOX_ATTEMPTS=10           # outbox delivery attempts before an event is parked
# MAX_SUBSCRIPTION_ATTEMPTS=10     # renewal attempts before a subscription lapses
# PAYOUT_MIN_EARNED_MINOR=2000000  # smallest payout, in earned-credit minor units
# PAYOUT_MIN_INTERVAL_MS=86400000  # minimum gap between a user's payout requests (24h)

# Fees and splits (basis points; 10000 = 100%).
# PLATFORM_FEE_BPS=1530           # transaction fee on Seller Content sales (15.3%)
# PAYOUT_FEE_BPS=150              # payout-rail fee on cash-out (PayPal ≈1.5%); the rail's cut, not VRChat revenue

# Risk velocity gate.
# VELOCITY_LIMIT_MINOR=100000     # spend-per-window ceiling, CREDIT minor units
# VELOCITY_WINDOW_MS=3600000      # rolling window for VELOCITY_LIMIT (1h)

# Settlement / maturity horizons per funding source (§0.17). An unknown source
# defaults to the conservative card horizon (safe by default).
# MATURITY_HORIZON_CARD_MS=604800000     # card top-up chargeback window (7d)
# MATURITY_HORIZON_CRYPTO_MS=86400000    # crypto top-up (1d)
# MATURITY_HORIZON_DEFAULT_MS=604800000  # unknown source → card horizon

# Payout SLAs — per-state staleness thresholds the reconcile sweep folds over (§0.6).
# SLA_PENDING_MS=30000
# SLA_SUBMITTED_MS=120000
# SLA_DEFAULT_MS=60000

# HTTP demo / server / worker.
# PORT=3000
# SHUTDOWN_TIMEOUT_MS=5000         # ms graceful shutdown waits for in-flight work before forcing exit
# WORKER_INTERVAL_MS=60000         # gap between worker sweep ticks
# WORKER_BATCH=100                 # rows a worker sweep processes per tick
