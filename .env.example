# Variable names only — never commit real values (.gitignore excludes .env*). Copy to .env and
# fill in. Config is read once at the edge (loadConfig, src/config.ts) and injected; library
# modules never read the environment.

# --- Required secrets (production fails fast if unset) ---------------------------

# NODE_ENV=production makes both secrets mandatory (loadConfig fails with CONFIG.INVALID); other
# values tolerate blanks for local dev. The serve/worker entry (scripts/main.ts) still refuses
# blank secrets in any NODE_ENV.
# NODE_ENV=production

# HMAC key used to verify inbound billing/settlement webhooks (e.g. a payment processor or store).
WEBHOOK_SECRET=

# Key the Signer uses to sign chain checkpoints and entitlement-gated URLs.
SIGNING_SECRET=

# Rotated-out signing secrets, comma-separated. Checkpoints sealed under a listed secret still
# verify; new seals sign under SIGNING_SECRET. Rotation moves the old secret here — never just
# replace SIGNING_SECRET (https://economy-lab-docs.pages.dev/economy/ops/key-rotation/).
# SIGNING_SECRETS_PRIOR=

# --- Production externals (required when NODE_ENV=production; dev uses stubs) -----
# In production the serve/worker entry fails fast if any is unset or malformed — it never falls
# back to the 1:1 dev rate or the auto-approve payout stub. Rates are fixed-point:
# usd_minor = floor(credit_minor * rate / 10^scale).

# CREDIT_BUY_RATE=8333         # buy rate: USD a user pays per credit at top-up.
# CREDIT_BUY_SCALE=6           #   rate 8333 / scale 6 => ~$0.008333 (~120 credits = $1).
# CREDIT_PAR_RATE=5            # par rate: a credit's backing and cash-out value, used by the backing check.
# CREDIT_PAR_SCALE=3           #   rate 5 / scale 3 => 1.00 credit backed by $0.005.
# PAYOUT_RATE=5                # payout rate: rate a seller's earned credits cash out at (equals par).
# PAYOUT_SCALE=3               #   rate 5 / scale 3 => 1.00 credit pays out $0.005.
# PROCESSOR_URL=https://payouts.internal/payout   # real payout provider (also honored in dev)
# PROCESSOR_API_KEY=                              # bearer token sent to PROCESSOR_URL

# --- Optional infrastructure (unset -> the dependency-free in-memory adapter) -----

# DATABASE_URL=postgres://economy:economy@localhost:55432/economy_lab  # pg adapter
# DATABASE_URL=mysql://root:economy@localhost:53306/economy_lab        # mysql adapter
# DB_POOL_MAX=10                                                      # max SQL pool connections; unset keeps the driver default of 10
# PG_URL=postgres://economy:economy@localhost:55432/economy_lab        # postgres alias when DATABASE_URL names another engine (tests/tools only)
# MYSQL_TEST_URL=mysql://root:economy@localhost:53306/economy_lab      # mysql backend for `npm test` (which loads .env). Postgres conformance uses DATABASE_URL or PG_URL. Unset -> those SQL tests skip.
# REDIS_URL=redis://localhost:56379                                    # read-through cache; unset -> no-op
# DISPATCHER_URL=https://bus.internal/economy                         # POST events to your event bus (SQS_QUEUE_URL wins; neither -> in-process)
# SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/.../economy  # SQS transport
# For LocalStack (docker compose), the AWS SDK reads these from the environment:
# AWS_REGION=us-east-1
# AWS_ENDPOINT_URL=http://localhost:54566               # point the SQS client at LocalStack
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test
# SQS_QUEUE_URL=http://localhost:54566/000000000000/economy  # LocalStack queue (create it first)

# In production every optional port must be set or explicitly declined; =1 declares this
# deployment deliberately runs without that port (a bare omission fails startup).
# DISPATCHER_DECLINED=1            # production runs without an event dispatcher
# PAYEES_DECLINED=1                # production runs without a payee directory
# ANCHOR_DECLINED=1                # production runs without a checkpoint anchor

# --- Optional overrides (the value shown is the documented default) --------------

# REPLAY_WINDOW_MS=300000          # accepted webhook timestamp skew (5 min)
# MAX_PAYOUT_ATTEMPTS=5            # provider attempts before a payout is reversed
# MAX_PAYOUT_AGE_MS=259200000      # a payout older than this (3d, outlasting weekend-adjacent settlement) is force-failed by the payouts sweep
# MAX_OUTBOX_ATTEMPTS=10           # outbox delivery attempts before an event is dead-lettered
# MAX_INBOX_ATTEMPTS=10            # inbox apply attempts before an inbound event is dead-lettered
# MAX_SUBSCRIPTION_ATTEMPTS=10     # renewal attempts before a subscription lapses
# PAYOUT_MIN_EARNED_MINOR=2000000  # smallest payout, in earned-credit minor units
# PAYOUT_MIN_INTERVAL_MS=86400000  # minimum gap between a user's payout requests (24h)

# Fees and splits (basis points; 10000 = 100%).
# PLATFORM_FEE_BPS=1530           # transaction fee on Seller Content sales (15.3%)
# PAYOUT_FEE_BPS=150              # payout-rail fee on cash-out (e.g. a payout provider ~1.5%). This is the rail's cut, not platform revenue.

# Risk velocity gate.
# In production VELOCITY_LIMIT_MINOR is required and startup fails fast without it; the dev default is demo-scale.
# VELOCITY_LIMIT_MINOR=100000     # single-knob per-window ceiling, CREDIT minor units; both classes fall back to it — required in production
# VELOCITY_INFLOW_LIMIT_MINOR=    # inflow ceiling (topUp, grantPromo); unset -> VELOCITY_LIMIT_MINOR
# VELOCITY_OUTFLOW_LIMIT_MINOR=   # outflow ceiling (spend, subscribe, requestPayout); unset -> VELOCITY_LIMIT_MINOR
# VELOCITY_WINDOW_MS=3600000      # rolling window for the velocity ceilings (1h)
# SUBSCRIPTION_PRICE_MIN_MINOR=10000    # smallest subscription price (100.00 CREDIT)
# SUBSCRIPTION_PRICE_MAX_MINOR=1000000  # largest subscription price (10,000.00 CREDIT)
# TOP_UP_BUNDLES_MINOR=60000,120000,240000,300000,360000,480000,600000,900000,1200000  # purchase catalog (CREDIT minor units); unset accepts any positive amount

# Platform sharding: rows each hot platform account is split across, so concurrent postings stop
# queueing on one row. Shard 0 keeps the bare id, so raising the count later is safe; drain
# before lowering it back to 1.
# PLATFORM_SHARDS=1               # 1 = unsharded

# The accrual split: spend and subscribe park seller shares on a settlement-accrual shard and the
# worker's drain sweep moves them to earned in batches, so concurrent buyers of one seller stop
# serializing on that seller's row. Meant to run with PLATFORM_SHARDS >= 2.
# ACCRUAL_DRAIN=0                 # 1 = on

# Maintenance pause window in epoch ms. Both bounds must be set to take effect, and the window is
# active when start <= now < end. While active it declines end-user writes with ECONOMY_PAUSED.
# Settlement (system) and operator fixes still flow.
# ECONOMY_PAUSE_START_MS=          # window opens (inclusive); unset -> no pause
# ECONOMY_PAUSE_END_MS=            # window closes (exclusive). This is the resumesAt the decline reports.

# Settlement / maturity horizons per funding source. Every rail defaults to the card horizon,
# the conservative anchor. Outside production an unset horizon is 0 (funds clear instantly);
# in production MATURITY_HORIZON_CARD_MS is required and startup fails fast without it.
# MATURITY_HORIZON_CARD_MS=604800000     # card top-up chargeback window (7d) — required in production
# MATURITY_HORIZON_CRYPTO_MS=604800000   # crypto top-up; card horizon by default — override when the rail's refund window is known
# MATURITY_HORIZON_STEAM_MS=604800000    # Steam wallet top-up; card horizon by default — override when the rail's refund window is known
# MATURITY_HORIZON_META_MS=604800000     # Meta store top-up; card horizon by default — override when the rail's refund window is known
# MATURITY_HORIZON_DEFAULT_MS=604800000  # unknown source -> card horizon

# Payout SLAs: per-state staleness thresholds the reconcile sweep folds over.
# SLA_PENDING_MS=30000
# SLA_SUBMITTED_MS=120000
# SLA_DEFAULT_MS=60000

# HTTP demo / server / worker.
# PORT=3000
# SHUTDOWN_TIMEOUT_MS=5000         # ms graceful shutdown waits for in-flight work before forcing exit
# WORKER_INTERVAL_MS=60000         # gap between worker sweep ticks
# WORKER_BATCH=100                 # rows a worker sweep processes per tick

# Optional @pwngh/taskq bridge (scripts/support/taskq-host.ts). TASKQ=1 puts the task table in
# the ledger's own database, which is what lets an enqueue share the ledger's transaction. A
# memory ledger has nothing to live beside, so TASKQ=1 without an override fails at startup.
# Requires the optional @pwngh/taskq package.
# TASKQ=1
# TASKQ_DATABASE_URL=              # split-deployment override only; scheme picks the engine, implies TASKQ=1
# TASKQ_POLL_MS=250

# Optional ops supervisor around the worker (scripts/support/ops-host.ts). OPS=1 wraps the
# composition's meter/logger in the `./ops` signal buffer and ticks the supervisor on its own
# interval; audit records stream to stdout as JSONL. Leaving it off changes nothing.
# OPS=1
# OPS_INTERVAL_MS=60000            # gap between supervisor ticks

# Optional Tilia payout rail via @pwngh/economy-edge (scripts/support/edge-host.ts).
# Off unless TILIA_CLIENT_ID is set; an incomplete opt-in fails at startup.
# TILIA_CLIENT_ID=
# TILIA_CLIENT_SECRET=
# TILIA_ACCOUNT_ID=                # integrator account id
# TILIA_ENVIRONMENT=staging        # staging | production
# TILIA_PAYEE_MAP=                 # dev payee routing as JSON, when no postgres ledger holds the table
# TILIA_PAYEE_DATABASE_URL=        # split-deployment override only; the payee table follows a postgres ledger (DATABASE_URL) by default
# TILIA_WEBHOOK_SECRET=            # HMAC secret for callback verification; required in production
# TILIA_WEBHOOK_SIGNATURE_HEADER=x-tilia-signature  # placeholder pending the ratified envelope

# --- Lab tooling (the bench/scale harness and the demos; not deployment config) ---
# Every dial is documented at its parse (BENCH_KEYS in scripts/support/harness.ts). A profile sets
# a coherent batch of defaults; an explicit var still wins over the profile.

# BENCH_PROFILE=default            # fast | default | thorough
# BENCH_OPS=500                    # measured ops per throughput sample
# BENCH_REPS=3                     # a throughput number is the best of this many runs
# BENCH_WARMUP=50                  # discarded ops before timing (0 honored)
# BENCH_CONCURRENCY=32             # in-flight submits for the concurrent sample
# BENCH_BUDGET_MS=5000             # per-sample time cap
# BENCH_BACKENDS=in-memory,postgres,mysql  # which backends to attempt, in order
# BENCH_REQUIRE=                   # backends whose absence FAILS the run (bench-prod: postgres,mysql)
# BENCH_OUTPUT=table               # table | json | both
# BENCH_JSON_PATH=                 # where JSON goes; unset = stdout
# BENCH_SEED=1                     # sequential-id seed, for reproducible ids
# BENCH_MODE=throughput            # throughput | contention
# BENCH_GATES=off                  # off (pure ledger work) | on (realistic policy gates)
# BENCH_SHARDS=1                   # PLATFORM_SHARDS for the measured economy
# BENCH_CONNS_PER_OP=1             # pooled connections one in-flight op holds
# BENCH_POOL_HEADROOM=4            # spare connections above conns_per_op * concurrency
# BENCH_POOL_MAX=                  # explicit pool-size override; unset = derived
# BENCH_POSTGRES_URL=              # bench-only URL override (else DATABASE_URL/PG_URL, else compose-local)
# BENCH_MYSQL_URL=                 # bench-only URL override (else DATABASE_URL/MYSQL_TEST_URL, else compose-local)
# BENCH_CURVE_USERS=20             # fixed user set for the integrity curve
# BENCH_CURVE_REPS=2               # reps per integrity-curve size
# SEGMENTS=8                       # scale-probe: history-growth segments
# SEG=500                          # scale-probe: operations per segment
# DEMO_RESET=                      # 1 = compose demo drops & recreates the schema (DESTROYS data)
